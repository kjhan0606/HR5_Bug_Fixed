/

&AMR_PARAMS
levelmin= 8
levelmax= 20
ngridtot= 15000000000    ! 1ngridtot = ~2400 Byte  (Suggested ngrid/npat = 1/5)
nparttot= 40000000000    ! 1nparttot = ~120 Byte
nexpand = 7,7,7,7,1,1
/

&REFINE_PARAMS
m_refine=11*8.,
ivar_refine=11               ! Last variable (ic_pvar_00006 for eache level contains zoom geometry information.)
var_cut_refine=0.01
mass_cut_refine=3.63798e-12  ! 3.63798e-12 for lmin13, 2.91037598e-11 for lmin12, 2.32831e-10 for lmin11, 1.86265e-09 for lmin10, 1.49012e-08 for lmin9, 1.19209e-07 for lmin8
interpol_var=1
interpol_type=0
sink_refine=.true.
/

&HYDRO_PARAMS
gamma=1.6666667
courant_factor=0.8
slope_type=1
scheme='muscl'
riemann='hllc'
pressure_fix=.true.
!beta_fix=0.5
/

&PHYSICS_PARAMS
cooling=.true.
haardt_madau=.true.
metal=.true.
z_ave=1.0e-3
eps_star=0.02     ! Value changed from the 0.02 default
del_star=55.
n_star=0.1d0
m_star=0.2
T2_star=750       ! Value changed from 1e4 value.
g_star=1.66667    ! Value changed from 1.66667
f_w=3.            ! Without kintetic
f_ek=0.3           ! Without kinetic
eps_sn2=2.
eps_sn1=2.
tol=1.d-3
yieldtablefilename='/scratch/g116a02/1_now/0_code/yield_table.asc'
z_reion=10.
omega_b=0.04
delayed_cooling=.false.
Mseed=1d4         ! Initial seed BH mass in Msun
sink_AGN=.true.   ! Activate AGN feedback
bondi=.true.      ! Activate Bondi accretion rate
drag=.true.       ! Activate gas drag force onto BHs
rAGN=4.d0         ! the size of the AGN bubble/jet
X_floor=1d-2      ! Eddington ratio threshold between radio and quasar mode
eAGN_K=1d0        ! Efficiency of the radio mode - jet
eAGN_T=1.5d-1     ! Efficiency of the quasar mode - heating
TAGN=0.0          ! Temperature increase before energy release in K
r_gal=50d0        ! Exclusion radius for the formation of new BHs in kpc
T2maxAGN=1d8      ! Maximum temperature increase due to AGN feedback
boost_acc=2d0     ! Power of the density scaling in the boost factor for gas accretion (Booth & Schaye 2009)
boost_drag=2d0    ! Power of the density scaling in the boost factor for gas drag force
vrel_merge=.true. ! Activate relative velocity criterion to merge BHs together
rmerge=4d0        ! Distance in dx_min units below which BHs are allowed to merge
spin_bh=.true.    ! Activate the BH spin evolution (Dubois et al, 2014). Impact the accretion and feedback in different ways.
mad_jet=.true.    ! Activate the MAD jet model (McKinney et al, 2012). Only works with spin_bh=.true.
/

&POISSON_PARAMS
epsilon=1.d-5
cg_levelmin=14
/

&LIGHTCONE_PARAMS
zmax_cone = 200.0
levelmin_cone=13
elongated_axis_cone1=1   !1:x 2:y 3:z
observer_cone1=0.0,0.5,0.5 ! (0-1)
minboxr_cone1=0.,0.4,0.4
maxboxr_cone1=1.,0.6,0.6
elongated_axis_cone2=-1   !1:x 2:y 3:z
observer_cone2=1.0,0.5,0.5 ! (0-1)
minboxr_cone2=0.,0.4,0.4
maxboxr_cone2=1.,0.6,0.6
/

&SPHERICAL_REGION_PARAMS
spherical_region=.true.
scenter=0.5,0.5,0.5   ! Code unit (0-1)
sradius=0.02          ! Code unit (0-1)
/

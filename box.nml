&RUN_PARAMS
cosmo=.true.
pic=.true.
poisson=.true.
hydro=.true.
nrestart=63
nremap=100
nsubcycle=1,1,1,1,2
ncontrol=1
verbose=.true.
sink=.true.             ! Activate sink (BH) particles
sinkprops=.false.       ! Dump BH properties at every coarse time step of the simulation
lightcone=.true.
/

&INIT_PARAMS
filetype='grafic'
initfile(1)='/scratch/g116a02/1_now/1_ic/output/level_008'
initfile(2)='/scratch/g116a02/1_now/1_ic/output/level_009'
initfile(3)='/scratch/g116a02/1_now/1_ic/output/level_010'
initfile(4)='/scratch/g116a02/1_now/1_ic/output/level_011'
initfile(5)='/scratch/g116a02/1_now/1_ic/output/level_012'
initfile(6)='/scratch/g116a02/1_now/1_ic/output/level_013'
/

&OUTPUT_PARAMS
walltime_hrs=60.
minutes_dump=30.
noutput=171
